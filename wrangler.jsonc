{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "procrastination-fix",
  "compatibility_date": "2026-07-23",
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "procrastination-fix.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  }
}
