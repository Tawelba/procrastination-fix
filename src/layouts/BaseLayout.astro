---
import '../styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = Astro.url.pathname } = Astro.props;
const canonicalUrl = new URL(canonical, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL('/og-image.jpg', Astro.site ?? Astro.url.origin)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.jpg', Astro.site ?? Astro.url.origin)} />
    <script is:inline>
      const savedTheme = localStorage.getItem('theme') || 'system';
      const initialTheme = savedTheme === 'system'
        ? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
        : savedTheme;
      document.documentElement.dataset.theme = initialTheme;
      document.documentElement.dataset.themeChoice = savedTheme;
    </script>
  </head>
  <body>
    <slot />
    <ThemeSwitcher />
    <script is:inline>
      const themeMedia = matchMedia('(prefers-color-scheme: dark)');
      const themeButtons = document.querySelectorAll('[data-theme-value]');

      const applyTheme = (choice, save = true) => {
        const root = document.documentElement;
        const resolved = choice === 'system' ? (themeMedia.matches ? 'dark' : 'light') : choice;
        root.dataset.theme = resolved;
        root.dataset.themeChoice = choice;
        if (save) localStorage.setItem('theme', choice);
        themeButtons.forEach((button) => {
          button.setAttribute('aria-pressed', String(button.dataset.themeValue === choice));
        });
      };

      themeButtons.forEach((button) => {
        button.addEventListener('click', () => applyTheme(button.dataset.themeValue));
      });

      themeMedia.addEventListener('change', () => {
        if ((localStorage.getItem('theme') || 'system') === 'system') applyTheme('system', false);
      });

      applyTheme(localStorage.getItem('theme') || 'system', false);
    </script>
  </body>
</html>
