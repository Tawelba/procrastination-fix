---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | Procrastination Fix" description="The requested page could not be found.">
  <main class="grid min-h-screen place-items-center px-5 text-center"><div><p class="text-sm font-extrabold uppercase tracking-widest text-action-600">404</p><h1 class="mt-3 text-5xl font-black tracking-tight">That page slipped away.</h1><p class="text-muted mt-4">Let’s bring your attention back to the next useful step.</p><a class="action-button focus-ring mt-7" href="/">Return home</a></div></main>
</BaseLayout>
