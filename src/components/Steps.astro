---
const steps = [
  {
    title: 'Pick Your Top 3',
    copy: 'Before each day, pick only three tasks that truly matter. Everything else can wait.',
    link: {
      href: 'https://get.todoist.io/csgt3ohsx0hb',
      label: 'Plan your top 3 with Todoist'
    }
  },
  {
    title: 'Set Timer + Focus Session',
    copy: 'Work for 25-minute chunks. Use Focusmate to pair with someone else and stay accountable.'
  },
  {
    title: 'Review & Adjust',
    copy: 'At the end of the day, review what you finished. Adjust your plan for tomorrow.'
  }
];
---
<section class="surface-soft py-20" id="how-it-works">
  <div class="container-shell">
    <div class="mx-auto max-w-2xl text-center"><h2 class="section-title">A Simple System That Actually Works</h2><p class="section-copy mt-3">Reduce the task, enter a focused session, and make the next day easier.</p></div>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {steps.map((step, index) => (
        <article class="border-ui surface shadow-card rounded-2xl border p-7 hover:-translate-y-1 hover:shadow-xl">
          <span class="grid h-10 w-10 place-items-center rounded-full bg-action-600 font-extrabold text-white">{index + 1}</span>
          <h3 class="mt-5 text-xl font-extrabold tracking-tight">{step.title}</h3>
          <p class="text-muted mt-3 leading-7">{step.copy}</p>
          {step.link && (
            <a
              class="focus-ring mt-5 inline-flex font-bold text-orange-700 underline decoration-orange-300 underline-offset-4 hover:text-orange-900"
              href={step.link.href}
              target="_blank"
              rel="nofollow sponsored noopener"
            >
              {step.link.label} <span aria-hidden="true">→</span>
            </a>
          )}
        </article>
      ))}
    </div>
    <p class="text-subtle mx-auto mt-5 max-w-2xl text-center text-xs leading-5">The Todoist link is an affiliate link. We may earn a commission if you sign up or purchase through it, at no additional cost to you.</p>
  </div>
</section>
