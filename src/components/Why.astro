---
const reasons = [
  ['01', 'Less decision friction', 'Three priorities give your attention somewhere specific to land.'],
  ['02', 'A smaller commitment', 'A 25-minute session feels approachable even when the full project does not.'],
  ['03', 'Visible accountability', 'A focus partner creates the gentle pressure that motivation often cannot.']
];
---
<section class="surface py-20" id="why-it-works">
  <div class="container-shell">
    <div class="mx-auto max-w-2xl text-center"><h2 class="section-title">Designed to Make Starting Easier</h2><p class="section-copy mt-3">The system reduces the three pressures that keep work stuck.</p></div>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {reasons.map(([number, title, copy]) => (
        <article class="border-ui rounded-2xl border p-7"><span class="grid h-11 w-11 place-items-center rounded-xl bg-orange-100 font-black text-orange-800">{number}</span><h3 class="mt-5 text-lg font-extrabold">{title}</h3><p class="text-muted mt-2 leading-7">{copy}</p></article>
      ))}
    </div>
  </div>
</section>
