<div class="theme-switcher" role="group" aria-label="Choose color mode">
  <button class="theme-choice focus-ring" type="button" data-theme-value="system" aria-label="Color mode: system" aria-pressed="false" title="Color mode: system">
    <span class="device-icon" aria-hidden="true"></span>
  </button>
  <button class="theme-choice focus-ring" type="button" data-theme-value="light" aria-label="Color mode: light" aria-pressed="false" title="Color mode: light">
    <span class="sun-icon" aria-hidden="true">☀</span>
  </button>
  <button class="theme-choice focus-ring" type="button" data-theme-value="dark" aria-label="Color mode: dark" aria-pressed="false" title="Color mode: dark">
    <span class="moon-icon" aria-hidden="true">◔</span>
  </button>
</div>
